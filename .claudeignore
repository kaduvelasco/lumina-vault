# ==============================================================================
# .aiexclude — LuminaDev AI Shield
#
# File automatically generated by the lumina git and lumina ai commands. 
# Check and adapt it to your project.
# ==============================================================================

# Security: Sensitive credentials and files (Stops Prompt Injection/Leaks)
.env
.env.*
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
config.php
wp-config.php
secrets.*
*.secret
.htpasswd
auth.json

# Block AI tool configuration directories (optional, if using local)
.claude/
.gemini/

# Dependencies and Data (Massive Token Economy)
node_modules/
vendor/
bower_components/
moodledata/
.git/
.svn/
.hg/

# IDEs and Virtual Environments
.vscode/
.idea/
.zed/
.DS_Store
Thumbs.db
__pycache__/
*.pyc
.venv/
env/
venv/

# Build, Cache, and Lockfiles (Don't let the AI ​​read the package-lock!)
dist/
build/
out/
.next/
.cache/
.tmp/
tmp/
*.log
package-lock.json
yarn.lock
pnpm-lock.yaml
composer.lock
*.min.js
*.min.css
*.map

# Binaries, Media, and Documents (AI doesn't "read" these files in the terminal)
*.jpg
*.jpeg
*.png
*.gif
*.svg
*.ico
*.webp
*.bmp
*.tiff
*.heic

*.mp3
*.mp4
*.webm
*.ogg
*.wav
*.flac
*.ttf
*.otf
*.woff
*.woff2

*.pdf
*.zip
*.tar.gz
*.rar
*.7z
*.mbz
*.iso
*.exe
*.bin
*.dll
*.so
